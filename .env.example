# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/meeting_reminder"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API + Google People API
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Twilio ──────────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15551234567"
# Public URL for TwiML webhook (use ngrok for local dev)
TWILIO_WEBHOOK_URL="https://your-domain.com/api/webhooks/twilio"

# ─── Trigger.dev ─────────────────────────────────────────────────────────────
# Get from: https://cloud.trigger.dev
TRIGGER_SECRET_KEY="tr_dev_xxxxxxxxxxxxxxxxxxxx"
TRIGGER_PROJECT_ID="your-trigger-project-id"

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex key: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here-64chars"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
